<?xml version="1.0"?>
<robot name="robby_explorer">

  <material name="blue"><color rgba="0 0 0.8 1"/></material>
  <material name="black"><color rgba="0 0 0 1"/></material>
  <material name="white"><color rgba="1 1 1 1"/></material>
  <material name="orange"><color rgba="1 0.5 0 1"/></material>

  <link name="base_link">
    <visual>
      <geometry><cylinder length="0.3" radius="0.2"/></geometry>
      <material name="blue"/>
    </visual>
  </link>

  <link name="right_wheel">
    <visual>
      <geometry><cylinder length="0.05" radius="0.1"/></geometry>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <material name="black"/>
    </visual>
  </link>

  <joint name="joint_right_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <axis xyz="0 1 0"/>
    <origin xyz="0 -0.22 -0.1"/>
  </joint>

  <link name="left_wheel">
    <visual>
      <geometry><cylinder length="0.05" radius="0.1"/></geometry>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <material name="black"/>
    </visual>
  </link>

  <joint name="joint_left_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <axis xyz="0 1 0"/>
    <origin xyz="0 0.22 -0.1"/>
  </joint>

  <link name="arm_base">
    <visual>
      <geometry><box size="0.1 0.1 0.2"/></geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="shoulder_joint" type="revolute">
    <parent link="base_link"/>
    <child link="arm_base"/>
    <origin xyz="0 0 0.25"/>
    <axis xyz="0 0 1"/> <limit effort="1000.0" lower="-1.57" upper="1.57" velocity="0.5"/>
  </joint>

  <link name="upper_arm">
    <visual>
      <geometry><box size="0.4 0.05 0.05"/></geometry>
      <origin xyz="0.2 0 0"/> <material name="orange"/>
    </visual>
  </link>

  <joint name="elbow_joint" type="revolute">
    <parent link="arm_base"/>
    <child link="upper_arm"/>
    <origin xyz="0 0 0.1"/>
    <axis xyz="0 1 0"/> <limit effort="1000.0" lower="-1.0" upper="1.0" velocity="0.5"/>
  </joint>

  <link name="hand">
    <visual>
      <geometry><sphere radius="0.05"/></geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="hand_joint" type="fixed">
    <parent link="upper_arm"/>
    <child link="hand"/>
    <origin xyz="0.4 0 0"/>
  </joint>

</robot>